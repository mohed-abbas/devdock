# =============================================================================
# DevDock environment configuration
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -------- Core (required) ----------------------------------------------------

# Postgres connection URL. Database must already exist.
DATABASE_URL=postgresql://devdock_app:devdock_dev_password@localhost:5432/devdock

# Auth.js v5
# AUTH_URL: public URL DevDock is served from (use http://localhost:3000 in dev).
# AUTH_SECRET: generate with `openssl rand -base64 32` (min 32 chars).
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-openssl-rand-base64-32

# -------- Docker -------------------------------------------------------------

DOCKER_SOCKET=/var/run/docker.sock

# -------- DevDock runtime ----------------------------------------------------

# Where per-environment data dirs and generated docker-compose.yml files live.
DEVDOCK_DATA_DIR=./data

# Max concurrent running environments (resource cap for single-VPS).
DEVDOCK_MAX_CONCURRENT_ENVS=3

# Terminal WebSocket server port (used by `npm run terminal:dev`).
TERMINAL_PORT=3001

# Optional: host path containing a `.claude/` directory to mount into dev
# containers so Claude Code CLI inherits your login.
# CLAUDE_CONFIG_PATH=/home/you/.claude

# Optional: Anthropic API key forwarded into containers for Claude Code.
# ANTHROPIC_API_KEY=

# -------- GitHub OAuth (optional — required for repo cloning) ----------------
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: ${AUTH_URL}/api/github/callback
# Set all three OR none — partial config is silently ignored at startup
# but OAuth flows will return an error response if any var is missing.

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Generate with: openssl rand -hex 32   (64 hex chars, 32 bytes)
# GITHUB_TOKEN_ENCRYPTION_KEY=

# -------- Preview subdomain proxy -------------------------------------------
# Each running environment is reachable at {env-id}.{PREVIEW_DOMAIN}.
# Both vars must be set AND must match. NEXT_PUBLIC_* is inlined at build time.
#
# Local dev (no DNS/nginx setup required — nip.io resolves *.127.0.0.1.nip.io
# to 127.0.0.1 automatically; include the Next dev port):
PREVIEW_DOMAIN=127.0.0.1.nip.io:3000
NEXT_PUBLIC_PREVIEW_DOMAIN=127.0.0.1.nip.io:3000
#
# Production (real wildcard domain + nginx wildcard vhost + wildcard TLS cert):
# PREVIEW_DOMAIN=preview.devdock.example.com
# NEXT_PUBLIC_PREVIEW_DOMAIN=preview.devdock.example.com

# -------- Production apps monitoring (optional) ------------------------------
# Directory containing your prod app docker-compose stacks to surface on the
# dashboard. Leave blank to hide the Production Apps section.
# PRODUCTION_APPS_DIR=/home/murx
